# Docker Compose 环境变量示例
# 复制为 .env 后 docker compose 会自动加载

# === 端口配置 ===
# WebSocket 服务暴露到宿主机的端口
WEBSOCKET_PORT=7420

# WebSocket 服务容器内部监听端口（通常不需要改）
WEBSOCKET_INTERNAL_PORT=7419

# === 网络配置 ===
# Docker 网络名称
DOCKER_NETWORK_NAME=websocket-network

# === 容器名称 ===
WEBSOCKET_CONTAINER_NAME=websocket-app
REDIS_CONTAINER_NAME=websocket-redis

# === 应用配置 ===
# Redis 连接地址（容器内网络名）
WEBSOCKET_REDIS_HOST=redis

# Redis 连接端口
WEBSOCKET_REDIS_PORT=6379

# Django DEBUG 模式
DEBUG=False
